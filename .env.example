# Database
DATABASE_URL="postgresql://user:password@localhost:5432/uni_events"
# Direct (non-pooled) connection, used only by the Prisma CLI for migrations.
# Required in production if DATABASE_URL points at a connection pooler (e.g.
# Neon's "-pooler" host) — pooled connections don't reliably support the
# advisory locks `prisma migrate deploy` needs. Safe to leave unset locally.
DIRECT_URL=""

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel Blob (image uploads) — from Vercel dashboard: Storage tab > create a Blob store
BLOB_READ_WRITE_TOKEN=""
